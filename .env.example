# ─── Server ────────────────────────────────────────────
HOST=0.0.0.0
PORT=1000

# ─── Browser ──────────────────────────────────────────
HEADLESS=false
DEFAULT_TIMEOUT_MS=10000
MAX_RETRIES=3
SCREENSHOT_DIR=.mcp_data/screenshots
DOWNLOADS_DIR=.mcp_data/downloads

# Use system Chrome instead of bundled Chromium: "chrome" or "msedge"
BROWSER_CHANNEL=
# Force device scale factor (for Windows scaling issues): 1, 0.9, 0.8, 1.25
BROWSER_SCALE_FACTOR=

# Viewport size
VIEWPORT_WIDTH=1920
VIEWPORT_HEIGHT=1080

# ─── Behavior ─────────────────────────────────────────
STEALTH_MODE=true
TURBO_MODE=false
INTERACTION_LOCK=true
AUTO_CLEANUP=true
SESSION_SCREENSHOT_SUBDIRS=true

# ─── Session Persistence ──────────────────────────────
# When true, browser_open reuses existing sessions for same domain
SESSION_REUSE=true

# ─── Vision AI (Gemini Flash) ─────────────────────────
# Get a FREE API key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
VISION_MODEL=gemini-2.0-flash
VISION_ENABLED=true
VISION_MAX_TOKENS=4096

# ─── Figma Integration ─────────────────────────────────
# Create token: Figma → Settings → Personal access tokens
FIGMA_API_TOKEN=your_figma_token_here
FIGMA_API_BASE_URL=https://api.figma.com/v1

# ─── Agent Scratchpad ─────────────────────────────────
# Isolated directory for agent testing files
SCRATCHPAD_DIR=.mcp_data/scratchpad
