{
  "name": "mcp-server-manager",
  "displayName": "MCP Server Manager",
  "description": "Automatically starts and manages an MCP server",
  "version": "1.0.0",
  "type": "module",
  "publisher": "gaurav",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mcp-manager.copyCopilotConfig",
        "title": "MCP: Copy Copilot Config"
      }
    ],
    "configuration": {
      "title": "MCP Server",
      "properties": {
        "mcp.serverPath": {
          "type": "string",
          "default": "C:/mcp-server/server.js",
          "description": "Path to the Node.js MCP server file."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "mcp": "node ./src/mcpServer.js",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "morgan": "^1.10.0",
    "playwright": "^1.52.0",
    "uuid": "^11.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  }
}
